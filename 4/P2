#include <iostream>
#include <vector>
#include <cstdlib>
#include <ctime>
#include <fstream>
using namespace std;

// Глобальный счетчик операций
long long operationCount = 0;

// Функция разделения массива (Хоара) со счетчиком
int partition(vector<int>& arr, int low, int high) {
    int pivot = arr[low];
    int i = low - 1;
    int j = high + 1;
    
    while (true) {
        // Считаем сравнения при движении i
        do {
            i++;
            operationCount++; // сравнение arr[i] < pivot
        } while (arr[i] < pivot);
        
        // Считаем сравнения при движении j
        do {
            j--;
            operationCount++; // сравнение arr[j] > pivot
        } while (arr[j] > pivot);
        
        if (i >= j) return j;
        
        // Считаем обмен
        swap(arr[i], arr[j]);
        operationCount++; // операция обмена
    }
}

// Рекурсивная функция быстрой сортировки
void quickSort(vector<int>& arr, int low, int high) {
    if (low < high) {
        int pi = partition(arr, low, high);
        quickSort(arr, low, pi);
        quickSort(arr, pi + 1, high);
    }
}

// Функция для сохранения результатов
