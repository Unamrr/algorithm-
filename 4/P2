    ofstream file(filename, ios::app);
    if (file.is_open()) {
        file << n << " " << operations << endl;
        file.close();
    }
}

int main() {
    srand(time(nullptr));
    
    cout << "Программа P2: Быстрая сортировка со счетчиком операций\n";
    cout << "==================================================\n";
    
    // Тестовые размеры массивов
    vector<int> testSizes = {100, 500, 1000, 5000, 10000};
    
    for (int n : testSizes) {
        cout << "\nТестирование на массиве размером " << n << ":\n";
        
        // Создаем случайный массив
        vector<int> arr(n);
        for (int i = 0; i < n; i++) {
            arr[i] = rand() % 10000;
        }
        
        // Обнуляем счетчик перед сортировкой
        operationCount = 0;
        
        // Сортируем
        quickSort(arr, 0, n - 1);
        
        // Выводим результат
        cout << "Количество операций: " << operationCount << endl;
        
        // Сохраняем в файл
        saveResults("operations.txt", n, operationCount);
        
        // Проверяем правильность сортировки (первые 10 элементов)
        cout << "Первые 10 элементов после сортировки: ";
        for (int i = 0; i < min(10, n); i++) {
            cout << arr[i] << " ";
        }
        cout << endl;
    }
    
    cout << "\nРезультаты сохранены в файл operations.txt" << endl;
    
    return 0;
}
