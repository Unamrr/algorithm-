#include<iostream>
#include<vector>
#include<queue>
using namespace std;

//функция, является ли граф деревом, проверка
bool isTree(const vector<vector<int>>& adj) {
	int n = adj.size();//получаем колво вершин, фвж это матрица смежности

	if (n == 0) return true;//типа пустой граф считаем деревом
	//проверяем что колво ребер должно быть n-1
	int edgeCount = 0;
	for (int i = 0; i < n; i++) {//цикл идет по J > i чтобы не считаеть ребро дважды
		for (int j = i + 1; j < n; j++) {//подсчитываем колво единиц в верхн треуг части матрицы
			if (adj[i][j] == 1) {
				edgeCount++;
			}
		}
	}
	if (edgeCount != n - 1)//если это усовие не выполняется то граф тчоно не дерево тк есть циклы или граф несвязный если меньше ребер
		return false;
	//проверяем что граф должен быть связным,? через обход в ширину
	vector<bool> visited(n, false);//массив посещенных вершин
	queue<int> q;//очередь для этогг7о
	q.push(0);//начинаем с вершины 0
	visited[0] = true;//помечаем как посещенную
	int visitedCount = 1;//сам счетчик эхтих посеещенных вершин

	while (!q.empty()) {
		int current = q.front();//берем вершину из очереди
		q.pop();

		for (int i = 0; i < n; i++) {
			if (adj[current][i] == 1 && !visited[i]) {//если есть вершина и она не посещена
				visited[i] = true;//помеяаем как посещенную
				visitedCount++;//увел счетчик
				q.push(i);//добавляем в очередь
			}
		}
	}
	return visitedCount == n;//есл колво посещенных вершин равно колву вершин то граф связный
}

//функция для вывода матрицы
void printMatrix(const vector<vector<int>>& adj) {
	int n = adj.size();
	for (int i = 0; i < n; i++) {
		for (int j = 0; j < n; j++) {
			cout << adj[i][j] << "";
		}
		cout << endl;
	}
}

